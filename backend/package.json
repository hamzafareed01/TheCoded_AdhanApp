{
  "name": "adhanhome-backend",
  "version": "2.0.0",
  "private": true,
  "type": "commonjs",
  "main": "index.js",
  "engines": {
    "node": ">=18.17"
  },
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "migrate:up": "node scripts/migrate.cjs",
    "start:with-migrations": "node scripts/migrate.cjs && node index.js",
    "healthcheck": "node -e \"require('http').get('http://127.0.0.1:'+(process.env.PORT||4000)+'/healthz',r=>process.exit(r.statusCode===200?0:1)).on('error',()=>process.exit(1))\""
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "mssql": "^11.0.1"
  }
}