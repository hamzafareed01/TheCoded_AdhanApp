{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/api/*",
      "/assets/*",
      "/audio/*",
      "/icons/*",
      "/sw.js",
      "/registerSW.js",
      "/favicon.ico",
      "/*.png",
      "/*.jpg",
      "/*.jpeg",
      "/*.svg",
      "/*.webmanifest"
    ]
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  },
  "routes": [
    {
      "route": "/index.html",
      "headers": { "Cache-Control": "no-cache" }
    },
    {
      "route": "/manifest.webmanifest",
      "headers": { "Cache-Control": "no-cache" }
    },
    {
      "route": "/sw.js",
      "headers": { "Cache-Control": "no-cache" }
    },
    {
      "route": "/registerSW.js",
      "headers": { "Cache-Control": "no-cache" }
    }
  ]
}
